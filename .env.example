# ============================================================
# Sahjanand Jewellers — Environment Configuration
# ============================================================
# Copy this file as .env and fill in the values.
#
# LOCAL DEV:  Use APP_HOST=127.0.0.1, leave VITE_HMR_HOST unset
# SERVER:     Use APP_HOST=0.0.0.0 and set VITE_HMR_HOST to your domain
# ============================================================

# MongoDB connection string
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sahjanand?retryWrites=true&w=majority&appName=Cluster0

# Ports
BACKEND_PORT=8002
FRONTEND_PORT=3550

# Debug mode (set False on production server)
DEBUG=True

# Auth
JWT_SECRET=your-secret-key-here
ADMIN_ID=Admin
ADMIN_PASSWORD=your-admin-password

# Host binding
# LOCAL:  127.0.0.1  (safe for macOS, no firewall prompts)
# SERVER: 0.0.0.0    (accept connections from all interfaces)
APP_HOST=127.0.0.1

# HMR Host (SERVER ONLY — leave commented out for local dev)
# Uncomment on the server so Vite HMR connects via your domain's HTTPS
# VITE_HMR_HOST=sahajanand.hkdigiverse.com
